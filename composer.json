{
    "name": "sympress/monolog-bundle",
    "description": "Monolog integration bundle for the WordPress kernel.",
    "type": "wordpress-muplugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Brian Schäffner",
            "email": "brian.schaeffner@sympress.de",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "sympress/kernel": "@dev",
        "monolog/monolog": "^3.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "friendsofphp/php-cs-fixer": "^3.94",
        "inpsyde/php-coding-standards": "^2.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.5",
        "symfony/var-dumper": "^7.3"
    },
    "autoload": {
        "psr-4": {
            "SymPress\\MonologBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SymPress\\MonologBundle\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --no-coverage",
        "test:unit": "phpunit --no-coverage --testsuite Unit",
        "cs:analyze": "phpstan analyse -c phpstan.neon.dist --no-progress",
        "cs:style": "php-cs-fixer fix --dry-run --diff --using-cache=no --config=.php-cs-fixer.dist.php",
        "cs:style:fix": "php-cs-fixer fix --using-cache=no --config=.php-cs-fixer.dist.php",
        "cs:audit": "phpcs --standard=phpcs.xml.dist",
        "cs:audit:fix": "phpcbf --standard=phpcs.xml.dist",
        "cs": [
            "@cs:style",
            "@cs:audit"
        ],
        "cs:fix": [
            "@cs:style:fix",
            "@cs:audit"
        ]
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "./../*",
            "options": {
                "symlink": true
            }
        }
    ],
    "extra": {
        "wordpress-install-dir": "vendor/wordpress/wordpress",
        "kernel": {
            "bundle": "SymPress\\MonologBundle\\MonologBundle",
            "entry": "monolog-bundle/monolog-bundle.php"
        }
    }
}
