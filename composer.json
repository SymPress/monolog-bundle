{
    "name": "sympress/monolog-bundle",
    "description": "Monolog integration bundle for the WordPress kernel.",
    "type": "wordpress-muplugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Brian Schäffner",
            "email": "brian.schaeffner@sympress.de",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "sympress/kernel": "dev-main",
        "monolog/monolog": "^3.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "friendsofphp/php-cs-fixer": "^3.94",
        "sympress/coding-standards": "dev-main",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.5",
        "symfony/var-dumper": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "SymPress\\MonologBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SymPress\\MonologBundle\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "cs": [
            "Composer\\Config::disableProcessTimeout",
            "phpcs --standard=phpcs.xml.dist"
        ],
        "cs:fix": [
            "Composer\\Config::disableProcessTimeout",
            "phpcbf --standard=phpcs.xml.dist"
        ],
        "static-analysis": [
            "Composer\\Config::disableProcessTimeout",
            "phpstan analyse --memory-limit=1G --no-progress -c phpstan.neon.dist"
        ],
        "tests": [
            "Composer\\Config::disableProcessTimeout",
            "phpunit --configuration phpunit.xml.dist --no-coverage"
        ],
        "qa": [
            "@cs",
            "@static-analysis",
            "@tests"
        ]
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "./../*",
            "options": {
                "symlink": true
            }
        }
    ],
    "extra": {
        "wordpress-install-dir": "vendor/wordpress/wordpress",
        "kernel": {
            "bundle": "SymPress\\MonologBundle\\MonologBundle",
            "entry": "monolog-bundle/monolog-bundle.php"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
