<?xml version="1.0"?>
<ruleset name="Monolog Bundle MU Plugin">
    <description>
        WordPress and security-focused coding standard audit for the Monolog bundle MU plugin.
    </description>

    <arg name="colors"/>
    <arg value="sp"/>
    <arg name="basepath" value="."/>
    <arg name="warning-severity" value="0"/>

    <config name="testVersion" value="8.5-"/>
    <config name="text_domain" value="monolog-bundle"/>

    <file>monolog-bundle.php</file>
    <file>src</file>

    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>.phpunit.cache/*</exclude-pattern>

    <rule ref="Inpsyde">
        <exclude name="Inpsyde.CodeQuality.NoAccessors"/>
        <exclude name="Inpsyde.CodeQuality.FunctionLength.TooLong"/>
        <exclude name="Generic.Metrics.CyclomaticComplexity.MaxExceeded"/>
        <exclude name="WordPress.Security.EscapeOutput.ExceptionNotEscaped"/>
        <exclude name="WordPress.PHP.DevelopmentFunctions.error_log_error_log"/>
        <exclude name="WordPress.PHP.POSIXFunctions"/>
    </rule>

    <rule ref="Inpsyde.CodeQuality.Psr4">
        <properties>
            <property name="psr4" type="array">
                <element key="SymPress\MonologBundle" value="src"/>
            </property>
        </properties>
    </rule>
</ruleset>
